<odoo>
    <!-- 1. Action first -->
    <record id="action_steel_order" model="ir.actions.act_window">
        <field name="name">Steel Order</field>
        <field name="res_model">steel.order</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- 2. Menus after action -->
    <menuitem id="menu_steel_root"
              name="Steel Manufacturing"
              sequence="10"/>

    <menuitem id="menu_steel_order"
              name="Steel Order"
              sequence="1"
              action="action_steel_order"
              parent="menu_steel_root"/>

    <record id="view_steel_order_tree" model="ir.ui.view">
        <field name="name">steel.order.tree</field>
        <field name="model">steel.order</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="product_id"/>
                <field name="state"/>
                <field name="total_cost"/>
                <field name="net_cost"/>
            </tree>
        </field>
    </record>

    <record id="view_steel_order_form" model="ir.ui.view">
        <field name="name">steel.order.form</field>
        <field name="model">steel.order</field>
        <field name="arch" type="xml">
            <form string="Steel Order">
                <sheet>
                    <header>
                        <button name="action_start"
                                string="Start"
                                type="object"
                                class="btn-primary"/>
                        <button name="action_done"
                                string="Done"
                                type="object"
                                class="btn-success"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,process,done"/>
                    </header>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="customer_id"/>
                            <field name="product_id"/>
                        </group>
                        <group>
                            <field name="sale_id"/>
                            <field name="lead_id"/>
                        </group>
                    </group>
                    <group string="Cost Details">
                        <field name="total_cost"/>
                        <field name="total_scrap_qty"/>
                        <field name="total_scrap_value"/>
                        <field name="net_cost"/>
                    </group>
                    <notebook>
                        <page string="Process Steps">
                            <field name="process_line_ids">
                                <tree editable="bottom">
                                    <field name="sequence"/>
                                    <field name="process_type"/>
                                    <field name="location_type"/>
                                    <field name="partner_id"/>
                                    <field name="cost"/>
                                    <field name="scrap_qty"/>
                                    <field name="scrap_price"/>
                                    <field name="scrap_value"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>