<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>
    <record id="action_tickets" model="ir.actions.act_window">
        <field name="name">Tickets</field>
        <field name="res_model">tickets</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_ticket_root" name="Tickets System" sequence="10"/>
    <menuitem id="menu_ticket" name="Tickets" parent="menu_ticket_root" action="action_tickets"/>
    <record id="view_tickets_tree" model="ir.ui.view">
        <field name="name">tickets.tree</field>
        <field name="model">tickets</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="subject"/>
                <field name="employee_id"/>
                <field name="assigned_to"/>
                <field name="priority"/>
                <field name="state"/>
            </tree>
        </field>
    </record>
    <record id="view_tickets_form" model="ir.ui.view">
        <field name="name">tickets.form</field>
        <field name="model">tickets</field>
        <field name="arch" type="xml">
            <form string="Ticket">
                <header>
                    <button name="action_start" type="object" string="Start"
                            invisible="state != 'new'"/>
                    <button name="action_closed" type="object" string="Close"
                            invisible="state != 'inprogress'"/>
                    <button name="action_hold" type="object" string="Hold"
                            invisible="state != 'inprogress'"/>
                    <button name="action_reset" type="object" string="Reset"
                            invisible="state not in ['closed','hold']"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,inprogress,hold,closed"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="subject"/>
                        <field name="description"/>
                    </group>
                    <group>
                        <field name="employee_id"/>
                        <field name="assigned_to"/>
                        <field name="department"/>
                    </group>
                    <group>
                        <field name="priority"/>
                        <field name="create_date" readonly="1"/>
                        <field name="closed_date" readonly="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
  </data>
</odoo>
