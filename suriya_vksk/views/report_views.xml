<odoo>

    <record id="hotel_sales_report_form" model="ir.ui.view">
        <field name="name">hotel.sales.report.form</field>
        <field name="model">hotel.sales.report</field>
        <field name="arch" type="xml">
            <form string="Sales Report">
                <group>
                    <field name="from_date"/>
                    <field name="to_date"/>
                </group>

                <footer>
                    <button name="generate_report"
                            string="Generate"
                            type="object"
                            class="btn-primary"/>
                </footer>

                <group>
                    <field name="total_sales" readonly="1"/>
                    <field name="total_orders" readonly="1"/>
                </group>
            </form>
        </field>
    </record>

    <record id="hotel_sales_report_action"
            model="ir.actions.act_window">
        <field name="name">Sales Report</field>
        <field name="res_model">hotel.sales.report</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>