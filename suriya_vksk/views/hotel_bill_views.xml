<odoo>

    <!-- Tree View -->

    <record id="hotel_bill_tree" model="ir.ui.view">
        <field name="name">hotel.bill.tree</field>
        <field name="model">hotel.bill</field>
        <field name="arch" type="xml">

            <tree>
                <field name="name"/>
                <field name="server_name"/>
                <field name="table_number"/>
                <field name="bill_date"/>
                <field name="total_amount"/>
            </tree>

        </field>
    </record>

    <!-- Form View -->

    <record id="hotel_bill_form" model="ir.ui.view">
        <field name="name">hotel.bill.form</field>
        <field name="model">hotel.bill</field>
        <field name="arch" type="xml">

            <form>

                <header>

                    <button name="%(hotel_bill_report_action)d"
                            string="Print Bill"
                            type="action"
                            class="btn-primary"/>

                </header>

                <sheet>

                    <group>

                        <field name="name" readonly="1"/>
                        <field name="server_name"/>
                        <field name="table_number"/>
                        <field name="bill_date"/>
                        <field name="company_id"/>

                    </group>

                    <notebook>

                        <page string="Food Items">

                            <field name="line_ids">

                                <tree editable="bottom">

                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="price"/>
                                    <field name="subtotal" readonly="1"/>

                                </tree>

                            </field>

                        </page>

                    </notebook>

                    <group>

                        <field name="total_amount" readonly="1"/>

                    </group>

                </sheet>

            </form>

        </field>
    </record>

    <!-- Action -->

    <record id="hotel_bill_action" model="ir.actions.act_window">

        <field name="name">Hotel Bills</field>
        <field name="res_model">hotel.bill</field>
        <field name="view_mode">tree,form</field>

    </record>

</odoo>